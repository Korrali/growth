DATABASE_URL=postgresql://korrali:PASSWORD@localhost:5432/growth_uat

NEXTAUTH_URL=https://growth-uat.korrali.com
# Used for session signing AND unsubscribe token HMAC
NEXTAUTH_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

RESEND_API_KEY=
# Transactional/internal email (auth magic links, founder notifications)
EMAIL_FROM=Korrali Growth <growth@korrali.com>
# Cold outbound — subdomain keeps korrali.com root domain reputation clean
GROWTH_FROM_NAME=Ashish from Korrali
GROWTH_FROM_EMAIL=ashish@outreach.korrali.com
# Inbound replies (MX for reply.outreach.korrali.com → Resend inbound servers)
RESEND_INBOUND_DOMAIN=reply.outreach.korrali.com
RESEND_WEBHOOK_SECRET=

# ─── Mailbox verification (REQUIRED to send — fail-closed without it) ──────────
# The contact finder guesses email patterns; we verify each mailbox BEFORE
# sending so we never bounce a wrong guess. Set exactly ONE provider key.
# Without a key, no discovered contact is sent (fail-closed) — this protects
# domain reputation. Recommended: NeverBounce (good catch-all detection).
NEVERBOUNCE_API_KEY=
# ZEROBOUNCE_API_KEY=
# EMAILABLE_API_KEY=
# Emergency override (NOT recommended — reintroduces bounce risk):
# GROWTH_ALLOW_UNVERIFIED_SEND=true

# AI model routing (all default to Haiku; upgrade individual slots by changing env var)
# Start here at week 1, then ramp: BULK_MODEL=claude-sonnet-4-6 after volume proves out
BULK_MODEL=
WRITING_MODEL=
HIGH_INTENT_MODEL=
ANTHROPIC_API_KEY=

# ─── Stripe (Growth-as-Service billing) ──────────────────────────────────────
# Enables: create Stripe customer + send setup-fee invoice from client detail page
# Get from: https://dashboard.stripe.com/apikeys (use test key in UAT)
STRIPE_SECRET_KEY=

# Safety — ramp MAX_SENDS_PER_DAY slowly: start at 10 for first week
MAX_SENDS_PER_DAY=20
MAX_SENDS_PER_DOMAIN_PER_DAY=1
SEND_WINDOW_START_HOUR=8
SEND_WINDOW_END_HOUR=18
SEND_TIMEZONE=America/New_York
QUIET_HOURS_START=20
QUIET_HOURS_END=8

FOUNDER_EMAIL=bhagat.ashish.a@gmail.com
APP_URL=https://growth-uat.korrali.com

# ─── Blog publishing (always targets production) ─────────────────────────────
# Shared secret between UAT and prod for the internal /api/internal/blog route.
# Set the same value in both UAT and prod .env files.
INTERNAL_API_SECRET=

# ─── Monitoring (GlitchTip self-hosted at glitchtip.korrali.com) ──────────────
SENTRY_DSN=https://PUBLIC_KEY@glitchtip.korrali.com/PROJECT_ID
NEXT_PUBLIC_SENTRY_DSN=https://PUBLIC_KEY@glitchtip.korrali.com/PROJECT_ID
SENTRY_ORG=korrali
SENTRY_PROJECT=growth-web

# ─── Community Scanner (Tavily) ───────────────────────────────────────────────
TAVILY_API_KEY=

# ─── Visitor Intent (ipinfo.io free tier: 50k req/month) ─────────────────────
# Optional — works without token at lower rate limit
IPINFO_TOKEN=

# ─── LinkedIn Distribution ────────────────────────────────────────────────────
# OAuth access token — needs w_organization_social scope for company page posting
LINKEDIN_ACCESS_TOKEN=
# Company page URN (preferred — posts anonymously as the brand)
# Format: urn:li:organization:XXXXXXXX
# Find it: GET https://api.linkedin.com/v2/organizationAcls?q=roleAssignee
# (with your access token) → look for organizationalTarget in the response
LINKEDIN_ORG_URN=
# Personal profile URN fallback (only used if LINKEDIN_ORG_URN is not set)
# Format: urn:li:person:XXXXXXXX
# Find it: GET https://api.linkedin.com/v2/me (with your access token)
LINKEDIN_PERSON_URN=
